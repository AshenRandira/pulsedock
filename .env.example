# API_PORT is preferred. PORT remains supported for legacy local setups.
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN="http://localhost:3000,http://localhost:3100"
NEXT_PUBLIC_API_URL="http://localhost:4000"
DATABASE_URL="postgresql://pulsedock:pulsedock@localhost:5432/pulsedock?schema=public"
POSTGRES_USER=pulsedock
POSTGRES_PASSWORD=pulsedock
POSTGRES_DB=pulsedock
POSTGRES_PORT=5432
CHECK_HISTORY_RETENTION_DAYS=30
# Alerts are disabled by default. Set this to smtp after configuring the fields below.
ALERT_PROVIDER=none
ALERT_EMAIL="alerts@example.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="pulsedock@example.com"
