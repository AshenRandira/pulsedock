{
  "name": "pulsedock",
  "version": "1.0.0",
  "private": true,
  "description": "Docker-first self-hosted uptime monitoring platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w web --",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w web",
    "prisma:generate:api": "npm run prisma:generate -w apps/api",
    "prisma:migrate:api": "npm run prisma:migrate -w apps/api",
    "prisma:studio:api": "npm run prisma:studio -w apps/api",
    "test:api": "npm run test -w apps/api",
    "test:e2e:api": "npm run test:e2e -w apps/api",
    "lint:api": "npm run lint -w apps/api",
    "lint:web": "npm run lint -w web",
    "format:api": "npm run format -w apps/api"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshenRandira/pulsedock.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AshenRandira/pulsedock/issues"
  },
  "homepage": "https://github.com/AshenRandira/pulsedock#readme"
}
